# Murph.AI NexGen Platform — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.

# Platform
APP_NAME="Murph.AI NexGen Platform"
APP_VERSION="1.1.0"
DEBUG=false

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://nexgen:CHANGE_ME@vm-db-01.control.local:5432/nexgen_platform

# Auth (Keycloak)
KEYCLOAK_URL=https://vm-iam-01.mgmt.local:8443
KEYCLOAK_REALM=nexgen
KEYCLOAK_CLIENT_ID=nexgen-platform
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=RS256

# AWS Bedrock (LLM — Bedrock only per v1.1)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_ONLY=true

# Ollama (DEFERRED until GPU installed)
OLLAMA_ENABLED=false

# Proxmox
PROXMOX_URL=https://192.168.4.58:8006
PROXMOX_TOKEN_ID=platform@pve!platform-token
PROXMOX_TOKEN_SECRET=CHANGE_ME

# HashiCorp Vault
VAULT_URL=https://vm-sec-01.mgmt.local:8200
VAULT_TOKEN=CHANGE_ME

# Murph.ai Integration
MURPH_HMAC_SECRET=CHANGE_ME
MURPH_WEBHOOK_SECRET=CHANGE_ME

# CORS
CORS_ORIGINS=["https://dashboard.nexgen.local"]
